# LLM 프로바이더: 로컬=github(빠름), HF=groq(무료·초고속) 또는 gemini
LLM_PROVIDER=github

# Groq (무료·초고속, OpenAI 호환) — console.groq.com/keys
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile  (기본값)

# GitHub Models (무료) — github.com/settings/tokens 에서 "Models: Read-only" 권한 PAT
GITHUB_TOKEN=

# Google Gemini (무료) — aistudio.google.com/apikey
GEMINI_API_KEY=

# DART 전자공시 Open API — opendart.fss.or.kr (기업개황·재무·공시)
DART_API_KEY=

# 네이버 검색 API — developers.naver.com (회사 뉴스)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 고용24/워크넷 채용정보 OpenAPI — work24.go.kr (인증키)
WORK24_API_KEY=
